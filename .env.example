# Copier ce fichier vers .env et renseigner les valeurs : cp .env.example .env
# Le fichier .env n'est JAMAIS versionné (cf. .gitignore).

# Couche de service Postgres (docker-compose + publish.py)
POSTGRES_DB=db_name
POSTGRES_USER=username
POSTGRES_PASSWORD=youy_password

# Clé API Claude — uniquement pour l'agent requêteur (page Streamlit / CLI)
# ANTHROPIC_API_KEY=sk-ant-...
