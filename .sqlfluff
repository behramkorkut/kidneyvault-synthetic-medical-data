# Linter SQL — cible les modèles dbt (templater dbt pour résoudre {{ ref() }}).
[sqlfluff]
dialect = duckdb
templater = dbt
max_line_length = 88

[sqlfluff:templater:dbt]
project_dir = dbt
profiles_dir = dbt

# Conventions : mots-clés en minuscules (cohérent avec les modèles existants).
[sqlfluff:rules:capitalisation.keywords]
capitalisation_policy = lower

[sqlfluff:rules:capitalisation.functions]
capitalisation_policy = lower
